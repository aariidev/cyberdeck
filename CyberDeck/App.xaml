<Application x:Class="CyberDeck.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- Cyberpunk Color Palette -->
        <Color x:Key="CyberBackground">#0B0C10</Color>
        <Color x:Key="CyberPanel">#1F2833</Color>
        <Color x:Key="CyberCyan">#45A29E</Color>
        <Color x:Key="CyberCyanLight">#66FCF1</Color>
        <Color x:Key="CyberMagenta">#FF003C</Color>
        <Color x:Key="CyberText">#C5C6C7</Color>
        
        <SolidColorBrush x:Key="BgBrush" Color="{StaticResource CyberBackground}"/>
        <SolidColorBrush x:Key="PanelBrush" Color="{StaticResource CyberPanel}"/>
        <SolidColorBrush x:Key="CyanBrush" Color="{StaticResource CyberCyan}"/>
        <SolidColorBrush x:Key="CyanLightBrush" Color="{StaticResource CyberCyanLight}"/>
        <SolidColorBrush x:Key="MagentaBrush" Color="{StaticResource CyberMagenta}"/>
        <SolidColorBrush x:Key="TextBrush" Color="{StaticResource CyberText}"/>

        <!-- Custom Button Style -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource CyanLightBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CyanBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource CyanBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource BgBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{StaticResource CyanLightBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource BgBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
